# BreadGo backend environment example
# Copy this file to .env for local development or set these values in your hosting provider.
# Do not commit real secrets, external delivery tokens, contact exports, or webhook credentials.

DATABASE_URL=postgresql+psycopg://breadgo_user:change_me@your-managed-postgres-host.example.com:5432/breadgo
JWT_SECRET_KEY=replace-with-a-random-secret-key-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_CORS_ORIGINS=["https://your-vercel-app.vercel.app","http://localhost:3000","http://127.0.0.1:3000"]

# Google OAuth customer signup/login.
# Keep disabled until Google OAuth credentials are configured in the deployment environment.
# Do not commit real GOOGLE_CLIENT_SECRET values.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-backend.example.com/api/v1/auth/google/callback
FRONTEND_URL=https://your-frontend.example.com
BACKEND_URL=https://your-backend.example.com

# External integrations are intentionally not configured in v0.1.1 demo-ready.
# PG payment, delivery, POS, email, Kakao, Push, Slack, Discord, and Webhook flows are mock/skeleton only.
