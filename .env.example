# BreadGo local development environment example.
# Copy values into backend/.env or your local shell as needed.
# Do not commit real production secrets, external API tokens, email/phone/address exports, or webhook credentials.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=breadgo
POSTGRES_USER=breadgo
POSTGRES_PASSWORD=breadgo_password
DATABASE_URL=postgresql+psycopg://breadgo:breadgo_password@localhost:5432/breadgo
JWT_SECRET_KEY=breadgo-local-development-secret-key-64-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# v0.1.1 demo-ready note:
# PG payment, delivery provider, POS provider, email, Kakao, Push, Slack, Discord, and Webhook integrations are mocked or not connected.
# Do not add real provider tokens here until a dedicated integration phase defines the storage and consent policy.
