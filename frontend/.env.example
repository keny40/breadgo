# BreadGo frontend environment example.
# NEXT_PUBLIC_API_BASE_URL should point to the FastAPI backend.
NEXT_PUBLIC_API_BASE_URL=https://your-render-backend-url.onrender.com

# Google OAuth is started through the backend.
# Frontend does not store Google client secrets.
NEXT_PUBLIC_GOOGLE_OAUTH_NOTE=Google OAuth uses backend /api/v1/auth/google/start when enabled.

# Product image file upload storage.
# Keep disabled unless storage credentials are configured in the deployment environment.
IMAGE_UPLOAD_ENABLED=false

# Option A: Vercel Blob on Vercel via OIDC.
# When a Blob Store is connected to this Vercel project, Vercel provides
# BLOB_STORE_ID and a short-lived VERCEL_OIDC_TOKEN at runtime.
# Do not commit real token values.
STORAGE_BACKEND=vercel_blob
BLOB_STORE_ID=

# Option B: Vercel Blob read-write token for non-OIDC environments.
# Prefer OIDC on Vercel. Use this only when running outside Vercel or when
# Vercel explicitly asks for a read-write token.
BLOB_READ_WRITE_TOKEN=

# Option C: S3-compatible storage such as Cloudflare R2 or AWS S3.
# Do not commit real access keys or secret keys.
# STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
# S3_BUCKET=breadgo-product-images
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# PUBLIC_ASSET_BASE_URL=https://assets.example.com

# v0.1.1 demo-ready does not use real email/Kakao/Push/Slack/Discord/Webhook delivery tokens.
